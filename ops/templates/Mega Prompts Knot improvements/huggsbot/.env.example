# Renomeie este arquivo para .env e cole SEU token (gere um novo no @BotFather com /revoke).
# NUNCA versione o .env com o token real.

TELEGRAM_TOKEN=cole_seu_novo_token_aqui

# Opcional — URL HTTPS pública do front (Mini App). Deixe vazio se não tiver hospedado ainda.
MINIAPP_URL=

# ── FreeScout (persistência real dos chamados) ─────────────────────────
# Se preenchido, os chamados são criados no FreeScout; senão, ficam em memória.
FREESCOUT_URL=http://localhost:8080
FREESCOUT_API_KEY=
FREESCOUT_MAILBOX_ID=1

# ── Webhook FreeScout → Telegram (opcional, para avisar respostas/status) ──
# Porta local onde freescout_webhook.py escuta os eventos do FreeScout.
FREESCOUT_WEBHOOK_PORT=8765
