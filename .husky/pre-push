#!/usr/bin/env sh
# Sincroniza refs do remoto antes do push (fetch nao-destrutivo).
# Antes: 'git pull --rebase origin main' — travava TODO push deste repo:
#   (1) o remoto usa 'master', nao 'main' (ref inexistente);
#   (2) rebase automatico exige arvore limpa e reescreveria feature branches.
# Trocado por um fetch informativo que nunca bloqueia o push.
echo "[Husky] Sincronizando refs do remoto (git fetch)..."
git fetch origin --quiet 2>/dev/null || true
exit 0
